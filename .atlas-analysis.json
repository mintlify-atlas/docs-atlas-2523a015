  "keyFeatures": [
    "Zero-knowledge proof generation and verification",
    "Decentralized virtual machine for private computations",
    "Program synthesis and execution",
    "Blockchain ledger with consensus mechanisms",
    "Cryptographic primitives (Poseidon, Varuna, Marlin)",
    "Account and transaction management",
    "WASM support for web integration",
    "CUDA acceleration for performance",
    "Modular architecture with 9 core crates"
  ],
  "publicApiSurface": [
    "snarkvm::prelude - Main prelude with commonly used types",
    "snarkvm::algorithms - Cryptographic algorithms and SNARKs",
    "snarkvm::circuit - Arithmetic circuits and constraint systems",
    "snarkvm::console - Console types (Account, Program, Network)",
    "snarkvm::synthesizer - Program synthesis and VM execution",
    "snarkvm::ledger - Blockchain ledger and consensus",
    "snarkvm::curves - Elliptic curve implementations",
    "snarkvm::fields - Finite field arithmetic",
    "snarkvm::parameters - Cryptographic parameters",
    "snarkvm::utilities - Helper functions and macros",
    "snarkvm::wasm - WebAssembly bindings",
    "VM::execute - Execute programs and generate proofs",
    "VM::deploy - Deploy programs to the network",
    "Ledger::load - Load blockchain state from storage",
    "Process::execute - Process program execution",
    "PrivateKey/ViewKey/Address - Account management"
  ]
}
